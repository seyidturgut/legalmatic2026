generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  orders         Order[]
  drafts         ContractDraft[]
  contracts      UserContract[]
  adminContracts Contract[]      @relation("ContractCreator")

  customers      Customer[]      @relation("CustomerCreator")
  assignedLeads  Lead[]          @relation("LeadAssignee")
  assignedTasks  Task[]          @relation("TaskAssignee")
  notes          Note[]          @relation("NoteAuthor")
  emailCampaigns EmailCampaign[] @relation("EmailCampaignCreator")
  emailTemplates EmailTemplate[] @relation("EmailTemplateCreator")
  emailLists     EmailList[]     @relation("EmailListCreator")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id             String   @id @default(uuid())
  title          String
  description    String   @db.Text
  price          Float
  slug           String   @unique
  category       String
  details        Json? // Stores rich content: intro, usage, scope, faq, etc.
  templateSchema String   @db.Text
  htmlContent    String?  @db.Text
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders       Order[]
  drafts       ContractDraft[]
  contracts    UserContract[]
  legislations Legislation[]   @relation("ProductLegislations")
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  productId String
  amount    Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ContractDraft {
  id          String   @id @default(cuid())
  userId      String
  productId   String
  answers     String   @db.Text // JSON string of answers
  currentStep Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // One draft per product per user
}

model UserContract {
  id        String   @id @default(cuid())
  userId    String
  productId String
  answers   String   @db.Text // Final snapshot of answers
  createdAt DateTime @default(now())
  status    String   @default("COMPLETED")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Legislation {
  id          String    @id @default(cuid())
  title       String
  type        String    @default("Kanun") // Kanun, Yönetmelik, Tebliğ, KHK
  referenceNo String?
  slug        String    @unique
  publishDate DateTime?
  summary     String?   @db.Text
  content     String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[] @relation("ProductLegislations")
}

model Contract {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String
  description String?  @db.Text
  content     String   @db.Text
  variables   Json?
  isActive    Boolean  @default(true)
  viewCount   Int      @default(0)
  usageCount  Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User @relation("ContractCreator", fields: [createdBy], references: [id])

  @@index([category])
  @@index([isActive])
  @@index([createdBy])
}

model Customer {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String   @unique
  phone          String?
  company        String?
  position       String?
  address        String?  @db.Text
  city           String?
  country        String?  @default("Türkiye")
  segment        String?
  source         String?
  brevoContactId Int?
  tags           String?  @db.Text
  customFields   String?  @db.Text
  status         String   @default("ACTIVE")
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy  User              @relation("CustomerCreator", fields: [createdById], references: [id])
  leads      Lead[]
  tasks      Task[]
  notes      Note[]
  emailLists EmailListMember[]
}

model Lead {
  id                String    @id @default(cuid())
  customerId        String
  title             String
  description       String?   @db.Text
  value             Float?
  status            String    @default("NEW")
  priority          String    @default("MEDIUM")
  source            String?
  assignedTo        String?
  expectedCloseDate DateTime?
  closedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedUser User?    @relation("LeadAssignee", fields: [assignedTo], references: [id])
  tasks        Task[]
  notes        Note[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  type        String    @default("GENERAL")
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  dueDate     DateTime?
  completedAt DateTime?
  customerId  String?
  leadId      String?
  assignedTo  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedUser User      @relation("TaskAssignee", fields: [assignedTo], references: [id])
}

model Note {
  id         String   @id @default(cuid())
  content    String   @db.Text
  type       String   @default("NOTE")
  customerId String?
  leadId     String?
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author   User      @relation("NoteAuthor", fields: [createdBy], references: [id])
}

model EmailCampaign {
  id              String    @id @default(cuid())
  name            String
  subject         String
  previewText     String?
  templateId      String?
  htmlContent     String?   @db.Text
  status          String    @default("DRAFT")
  scheduledAt     DateTime?
  sentAt          DateTime?
  brevoId         Int?
  recipientCount  Int       @default(0)
  openRate        Float?
  clickRate       Float?
  bounceRate      Float?
  unsubscribeRate Float?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  template  EmailTemplate?   @relation(fields: [templateId], references: [id])
  creator   User             @relation("EmailCampaignCreator", fields: [createdBy], references: [id])
  lists     CampaignList[]
  analytics EmailAnalytics[]
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  subject     String   @default("")
  description String?  @db.Text
  previewText String?
  htmlContent String   @db.Text
  jsonDesign  String?  @db.LongText
  thumbnail   String?
  category    String?
  isActive    Boolean  @default(true)
  createdById String   @map("createdBy")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator   User            @relation("EmailTemplateCreator", fields: [createdById], references: [id])
  campaigns EmailCampaign[]
}

model EmailList {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  brevoListId Int?
  memberCount Int      @default(0)
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator   User              @relation("EmailListCreator", fields: [createdBy], references: [id])
  members   EmailListMember[]
  campaigns CampaignList[]
}

model EmailListMember {
  id         String   @id @default(cuid())
  listId     String
  customerId String
  status     String   @default("SUBSCRIBED")
  addedAt    DateTime @default(now())

  list     EmailList @relation(fields: [listId], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([listId, customerId])
}

model CampaignList {
  id         String @id @default(cuid())
  campaignId String
  listId     String

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  list     EmailList     @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([campaignId, listId])
}

model EmailAnalytics {
  id         String   @id @default(cuid())
  campaignId String
  eventType  String
  email      String
  timestamp  DateTime
  metadata   String?  @db.Text

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, eventType])
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
